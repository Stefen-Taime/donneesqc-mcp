# ── Serveur MCP ────────────────��────────────────────────────────────
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_ENV=local
LOG_LEVEL=INFO

# ── Données Québec (CKAN) ──────────────────────────────────────────
DQ_API_URL=https://www.donneesquebec.ca/recherche/api/3/action
DQ_BASE_URL=https://www.donneesquebec.ca/recherche

# ── Ville de Montréal (CKAN) ────────────────���──────────────────────
MTL_API_URL=https://donnees.montreal.ca/api/3/action
MTL_BASE_URL=https://donnees.montreal.ca

# ── Géospatial (IGO / OGC) ─────────────────────────���───────────────
GEO_WMS_URL=https://geoegl.msp.gouv.qc.ca/ws/igo_gouvouvert.fcgi
GEO_WFS_URL=https://geoegl.msp.gouv.qc.ca/ws/igo_gouvouvert.fcgi

# ── Geocodage (Adresses Québec / ICherche) ─────────────────────────
GEOCODER_URL=https://geoegl.msp.gouv.qc.ca/apis/icherche

# ── HTTP ────────────────────────────────────────────────────────────
# HTTP_TIMEOUT=30.0
# HTTP_MAX_RETRIES=3

# ── Limites de téléchargement ──────────────────────────────────────
